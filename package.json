{
  "name": "agent-master",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "node build/build.mjs",
    "dev": "node build/build.mjs && python3 -m http.server 3000 -d site",
    "watch": "node --watch-path=content --watch-path=build build/build.mjs",
    "clean": "rm -rf site",
    "clean-branches": "git fetch -p && git for-each-ref refs/heads --format '%(refname:short) %(upstream:track)' | awk '$2 == \"[gone]\" {print $1}' | xargs git branch -D",
    "prepare": "husky"
  },
  "dependencies": {
    "@vercel/analytics": "^2.0.1",
    "marked": "^15.0.0"
  },
  "devDependencies": {
    "husky": "^9.1.7"
  }
}
